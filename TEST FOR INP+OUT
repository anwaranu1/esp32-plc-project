#include <Arduino.h>
#include <WiFi.h>
#include <WebServer.h>

// -----------------------------------------------------------------------------
// Wi-Fi configuration
// -----------------------------------------------------------------------------
// Set your Wi-Fi credentials here. Leave both blank to start in Access Point mode.
const char* wifiSsid = "";
const char* wifiPassword = "";

const char* apSsid = "ESP32PLC-Test";
const char* apPassword = "12345678";

// -----------------------------------------------------------------------------
// PLC pin mapping
// -----------------------------------------------------------------------------
const uint8_t inputPins[8]  = {33, 25, 36, 39, 34, 35, 32, 26};
const uint8_t outputPins[8] = {21, 19, 18, 5, 16, 4, 2, 15};
const char* inputLabels[8]  = {"I1", "I2", "I3", "I4", "I5", "I6", "I7", "I8"};
const char* outputLabels[8] = {"S1", "S2", "S3", "S4", "S5", "S6", "S7", "S8"};
bool outputStates[8] = {false, false, false, false, false, false, false, false};

WebServer server(80);

enum NetworkMode {
  MODE_UNKNOWN,
  MODE_STA,
  MODE_AP,
  MODE_CONNECTING
};

NetworkMode networkMode = MODE_UNKNOWN;
unsigned long connectStartMs = 0;
const unsigned long connectTimeoutMs = 20000;

// -----------------------------------------------------------------------------
// Setup helper functions
// -----------------------------------------------------------------------------
void initializeInputs() {
  for (uint8_t i = 0; i < 8; i++) {
    pinMode(inputPins[i], INPUT);
  }
}

void initializeOutputs() {
  for (uint8_t i = 0; i < 8; i++) {
    pinMode(outputPins[i], OUTPUT);
    digitalWrite(outputPins[i], LOW);
    outputStates[i] = false;
  }
}

void setOutputState(uint8_t index, bool state) {
  if (index >= 8) {
    return;
  }
  outputStates[index] = state;
  digitalWrite(outputPins[index], state ? HIGH : LOW);
}

// -----------------------------------------------------------------------------
// Wi-Fi and AP management
// -----------------------------------------------------------------------------
void startAccessPoint() {
  WiFi.disconnect(true);
  WiFi.mode(WIFI_OFF);
  delay(50);
  WiFi.mode(WIFI_AP);
  WiFi.softAPConfig(IPAddress(192, 168, 4, 1), IPAddress(192, 168, 4, 1), IPAddress(255, 255, 255, 0));
  WiFi.softAP(apSsid, apPassword);
  networkMode = MODE_AP;

  Serial.println("Access Point mode started.");
  Serial.print("AP IP address: ");
  Serial.println(WiFi.softAPIP());
}

void startWiFi() {
  WiFi.disconnect(true);
  WiFi.mode(WIFI_OFF);
  delay(50);
  WiFi.mode(WIFI_STA);
  WiFi.persistent(false);
  WiFi.setAutoReconnect(true);
  WiFi.begin(wifiSsid, wifiPassword);
  networkMode = MODE_CONNECTING;
  connectStartMs = millis();

  Serial.println("Connecting to Wi-Fi...");
}

void updateWiFiStatus() {
  if (networkMode != MODE_CONNECTING) {
    return;
  }

  if (WiFi.status() == WL_CONNECTED) {
    networkMode = MODE_STA;
    Serial.println("Wi-Fi connected.");
    Serial.print("Local IP address: ");
    Serial.println(WiFi.localIP());
    return;
  }

  if (millis() - connectStartMs >= connectTimeoutMs) {
    Serial.println("Wi-Fi connection timed out.");
    Serial.println("Falling back to Access Point mode.");
    startAccessPoint();
  }
}

