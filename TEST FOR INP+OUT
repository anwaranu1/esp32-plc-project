void handleRoot() {
  server.send(200, "text/html", buildWebPage());
}

void handleStatus() {
  String response = "{";
  response += "\"ip\":\"";
  response += (networkMode == MODE_AP) ? WiFi.softAPIP().toString() : WiFi.localIP().toString();
  response += "\",";

  response += "\"wifi\":\"";
  switch (networkMode) {
    case MODE_STA:
      response += "Connected";
      break;
    case MODE_CONNECTING:
      response += "Connecting";
      break;
    case MODE_AP:
      response += "Access Point";
      break;
    default:
      response += "Unknown";
      break;
  }
  response += "\",";

  response += "\"uptime\":" + String(millis() / 1000) + ",";
  response += "\"heap\":" + String(ESP.getFreeHeap()) + ",";

  response += "\"inputs\": [";
  for (uint8_t i = 0; i < 8; i++) {
    bool state = digitalRead(inputPins[i]) == HIGH;
    response += "{\"label\":\"" + String(inputLabels[i]) + "\",\"state\":" + String(state ? 1 : 0) + "}";
    if (i < 7) response += ",";
  }
  response += "],";

  response += "\"outputs\": [";
  for (uint8_t i = 0; i < 8; i++) {
    response += "{\"label\":\"" + String(outputLabels[i]) + "\",\"state\":" + String(outputStates[i] ? 1 : 0) + "}";
    if (i < 7) response += ",";
  }
  response += "]}";

  server.send(200, "application/json", response);
}

void handleControl() {
  if (!server.hasArg("output") || !server.hasArg("state")) {
    server.send(400, "application/json", "{\"ok\":false,\"error\":\"Missing parameters\"}");
    return;
  }

  int index = server.arg("output").toInt();
  int state = server.arg("state").toInt();

  if (index < 0 || index > 7) {
    server.send(400, "application/json", "{\"ok\":false,\"error\":\"Invalid output index\"}");
    return;
  }

  setOutputState(index, state != 0);
  server.send(200, "application/json", "{\"ok\":true}");
}

void setup() {
  Serial.begin(115200);
  delay(10);
  Serial.println();
  Serial.println("ESP32 Mini PLC Hardware Test Utility");

  initializeInputs();
  initializeOutputs();

  if (strlen(wifiSsid) > 0 && strlen(wifiPassword) > 0) {
    startWiFi();
  } else {
    startAccessPoint();
  }

  server.on("/", HTTP_GET, handleRoot);
  server.on("/status", HTTP_GET, handleStatus);
  server.on("/control", HTTP_GET, handleControl);
  server.begin();

  Serial.println("Web server started.");
}

void loop() {
  server.handleClient();
  updateWiFiStatus();
}
