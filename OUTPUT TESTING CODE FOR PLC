#include <Arduino.h>
#include <WiFi.h>
#include <WebServer.h>

// -----------------------------------------------------------------------------
// Wi-Fi configuration
// -----------------------------------------------------------------------------
// Leave these empty to start in Access Point mode.
const char* wifiSsid = "hotspot";
const char* wifiPassword = "12345678";

const char* apSsid = "ESP32-Controls";
const char* apPassword = "12345678";

// -----------------------------------------------------------------------------
// Output mapping for the required GPIOs
// -----------------------------------------------------------------------------
const uint8_t outputPins[] = {21, 19, 18, 5, 16, 4, 2, 15};
const char* outputNames[] = {"S1", "S2", "S3", "S4", "S5", "S6", "S7", "S8"};

const uint8_t outputCount = sizeof(outputPins) / sizeof(outputPins[0]);
bool outputStates[outputCount];

WebServer server(80);

enum WiFiState {
  WIFI_IDLE,
  WIFI_CONNECTING,
  WIFI_CONNECTED,
  WIFI_AP_READY
};

WiFiState wifiState = WIFI_IDLE;
unsigned long wifiStartTime = 0;
const unsigned long wifiTimeoutMs = 20000;

// -----------------------------------------------------------------------------
// Helper functions
// -----------------------------------------------------------------------------
void initializeOutputs() {
  for (uint8_t i = 0; i < outputCount; i++) {
    pinMode(outputPins[i], OUTPUT);
    digitalWrite(outputPins[i], LOW);
    outputStates[i] = false;
  }
}

void setOutputState(uint8_t index, bool state) {
  if (index >= outputCount) {
    return;
  }

  outputStates[index] = state;
  digitalWrite(outputPins[index], state ? HIGH : LOW);
}

void startAccessPoint() {
  WiFi.disconnect(true);
  WiFi.mode(WIFI_OFF);
  WiFi.mode(WIFI_AP);
  WiFi.softAPConfig(IPAddress(192, 168, 4, 1), IPAddress(192, 168, 4, 1), IPAddress(255, 255, 255, 0));
  WiFi.softAP(apSsid, apPassword);
  wifiState = WIFI_AP_READY;

  Serial.println("Access Point started.");
  Serial.print("AP IP: ");
  Serial.println(WiFi.softAPIP());
}

void connectToWiFi() {
  if (strlen(wifiSsid) == 0) {
    startAccessPoint();
    return;
  }

  WiFi.disconnect(true);
  WiFi.mode(WIFI_OFF);
  WiFi.mode(WIFI_STA);
  WiFi.persistent(false);
  WiFi.setAutoReconnect(true);
  WiFi.begin(wifiSsid, wifiPassword);
  wifiState = WIFI_CONNECTING;
  wifiStartTime = millis();

  Serial.println("Connecting to Wi-Fi...");
}

void updateWiFiStatus() {
  if (wifiState == WIFI_CONNECTING) {
    if (WiFi.status() == WL_CONNECTED) {
      wifiState = WIFI_CONNECTED;
      Serial.println("Wi-Fi connected.");
      Serial.print("IP Address: ");
      Serial.println(WiFi.localIP());
    } else if (millis() - wifiStartTime >= wifiTimeoutMs) {
      Serial.println("Wi-Fi connection timed out, switching to Access Point mode.");
      startAccessPoint();
    }
  }
}

String buildWebPage() {
  String html = R"HTML(
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
