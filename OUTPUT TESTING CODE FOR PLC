      <div class="ip" id="ipLabel">IP: --</div>
    </div>

    <div class="grid" id="outputGrid"></div>
  </div>

  <script>
    const outputGrid = document.getElementById('outputGrid');
    const ipLabel = document.getElementById('ipLabel');

    function createCard(index, name, gpio, state) {
      const card = document.createElement('div');
      card.className = 'card';
      card.innerHTML = `
        <h2>${name}</h2>
        <div class="status ${state ? 'on' : 'off'}">${state ? 'ON' : 'OFF'}</div>
