}

void handleRoot() {
  server.send(200, "text/html", buildWebPage());
}

void handleStatus() {
  String payload = "{\"ip\":\"";
  payload += (WiFi.getMode() == WIFI_AP) ? WiFi.softAPIP().toString() : WiFi.localIP().toString();
  payload += "\",\"outputs\":[";

  for (uint8_t i = 0; i < outputCount; i++) {
    payload += "{\"name\":\"";
    payload += outputNames[i];
    payload += "\",\"gpio\":";
    payload += outputPins[i];
    payload += ",\"state\":";
    payload += outputStates[i] ? "1" : "0";
    payload += "}";

    if (i < outputCount - 1) {
      payload += ",";
    }
  }

  payload += "]}";
  server.send(200, "application/json", payload);
}

void handleControl() {
  if (!server.hasArg("output") || !server.hasArg("state")) {
    server.send(400, "application/json", "{\"ok\":false,\"error\":\"missing parameters\"}");
    return;
  }

  int index = server.arg("output").toInt();
  int state = server.arg("state").toInt();

  if (index >= 0 && index < outputCount) {
    setOutputState(index, state != 0);
    server.send(200, "application/json", "{\"ok\":true}");
  } else {
    server.send(400, "application/json", "{\"ok\":false,\"error\":\"invalid output\"}");
  }
}

void setup() {
  Serial.begin(115200);
  initializeOutputs();

  connectToWiFi();

  server.on("/", HTTP_GET, handleRoot);
  server.on("/status", HTTP_GET, handleStatus);
  server.on("/control", HTTP_GET, handleControl);
  server.begin();

  Serial.println("Web server started.");
}

void loop() {
  server.handleClient();
  updateWiFiStatus();
}
